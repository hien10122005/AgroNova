<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#ECFDF5"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            
            <ImageView
                android:id="@+id/imgStatIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#10B981" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Trend pill -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#F1F5F9"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintBottom_toBottomOf="@id/iconContainer"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/txtTrend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+5.2%"
                android:textColor="#10B981"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtStatValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="125.4M"
            android:textColor="#0F172A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/iconContainer"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtStatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Doanh thu tháng"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/txtStatValue"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
