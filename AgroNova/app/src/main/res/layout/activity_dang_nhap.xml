<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    tools:context=".MainActivity">

    <!-- Decorative Top Background: Premium Gradient -->
    <View
        android:id="@+id/topBg"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:background="@drawable/bg_tieu_de_chuyen_mau"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Decorative Elements: Liquid Glass / Refraction style circles -->
    <ImageView
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:src="@drawable/bg_hinh_tron_trang"
        android:alpha="0.05"
        android:translationX="140dp"
        android:translationY="-80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/bg_hinh_tron_trang"
        android:alpha="0.04"
        android:translationX="-100dp"
        android:translationY="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="48dp"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header Content -->
            <LinearLayout
                android:id="@+id/headerContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="64dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Logo in premium glass-like card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1AFFFFFF">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_logo"
                        android:padding="20dp"
                        app:tint="@color/primary_mint" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Tighter letter spacing for premium look -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="AgroNova"
                    android:textColor="#FFFFFF"
                    android:textSize="36sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.04" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kết nối nông nghiệp Việt"
                    android:textColor="#CCFFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.01" />
            </LinearLayout>

            <!-- Login Form Card (Anti-Slop Bento style) -->
            <!-- We add an inner subtle stroke for the "refraction" look -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/formCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="40dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="32dp"
                app:cardElevation="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                app:layout_constraintTop_toBottomOf="@id/headerContent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="32dp"
                    android:paddingTop="40dp"
                    android:paddingBottom="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng nhập"
                        android:textColor="#0F172A"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Chào mừng bạn quay trở lại!"
                        android:textColor="#64748B"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="15sp"
                        android:layout_marginBottom="36dp" />

                    <!-- Custom Email Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        android:textAllCaps="true"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_o_nhap_lieu"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="24dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_anh_dai_dien"
                            app:tint="#94A3B8" />
                        <EditText
                            android:id="@+id/edtEmail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="Nhập email của bạn"
                            android:inputType="textEmailAddress"
                            android:paddingStart="12dp"
                            android:textColor="#0F172A"
                            android:fontFamily="sans-serif-medium"
                            android:textColorHint="#94A3B8"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Custom Password Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mật khẩu"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        android:textAllCaps="true"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_o_nhap_lieu"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="16dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_khoa"
                            app:tint="#94A3B8" />
                        <EditText
                            android:id="@+id/edtPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Nhập mật khẩu"
                            android:inputType="textPassword"
                            android:paddingStart="12dp"
                            android:textColor="#0F172A"
                            android:fontFamily="sans-serif-medium"
                            android:textColorHint="#94A3B8"
                            android:textSize="16sp" />
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_view"
                            android:padding="2dp"
                            app:tint="#94A3B8"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginBottom="36dp"
                        android:text="Quên mật khẩu?"
                        android:textColor="@color/primary_mint"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingVertical="4dp" />

                    <!-- Premium flat button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Đăng Nhập"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        app:backgroundTint="@color/primary_mint"
                        app:cornerRadius="20dp"
                        app:elevation="0dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chưa có tài khoản? "
                            android:textColor="#64748B"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/txtRegister"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đăng ký ngay"
                            android:textColor="@color/primary_mint"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="2dp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

